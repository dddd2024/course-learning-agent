# 运行环境（development | production）
ENVIRONMENT=development

# 数据库
DATABASE_URL=sqlite:///./course_assistant.db

# JWT 密钥（生产环境务必更换为随机长字符串）
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传
UPLOAD_DIR=storage/uploads
PARSED_DIR=storage/parsed

# LLM 配置（mock 模式无需填）
LLM_PROVIDER=mock
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
# 用于加密用户级 API Key 的 Fernet 密钥（生产环境必须更换）
LLM_CONFIG_SECRET_KEY=change-me-please

# CORS（逗号分隔的来源列表，生产环境应改为实际前端域名）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
