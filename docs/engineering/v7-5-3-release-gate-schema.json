{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://course-learning-agent.local/schemas/v7-5-3-release-gate.json",
  "title": "V7.5.3 Local Release Gate Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "e2e_run_id",
    "tested_sha",
    "final_sha",
    "head_unchanged",
    "dirty_before",
    "dirty_after",
    "steps",
    "e2e",
    "teardown",
    "normal_uploads_unchanged",
    "passed"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "e2e_run_id": { "type": "string", "minLength": 1 },
    "tested_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "final_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "head_unchanged": { "const": true },
    "dirty_before": { "const": false },
    "dirty_after": { "const": false },
    "steps": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["name", "command", "cwd", "exit_code", "stdout", "stderr"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "array", "items": { "type": "string" } },
          "cwd": { "type": "string" },
          "exit_code": { "const": 0 },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" }
        }
      }
    },
    "e2e": {
      "type": "object",
      "required": ["passed", "failed", "flaky", "skipped"],
      "properties": {
        "passed": { "const": 6 },
        "failed": { "const": 0 },
        "flaky": { "const": 0 },
        "skipped": { "const": 0 }
      }
    },
    "teardown": {
      "type": "object",
      "required": ["run_id", "passed", "normal_uploads_unchanged", "cleanup_passed"],
      "properties": {
        "run_id": { "type": "string" },
        "passed": { "const": true },
        "normal_uploads_unchanged": { "const": true },
        "cleanup_passed": { "const": true }
      }
    },
    "normal_uploads_unchanged": { "const": true },
    "passed": { "const": true }
  }
}
